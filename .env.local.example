# Copy this to .env.local and fill in your values
# Never commit .env.local to git

# Cloudflare Images (for photos)
NEXT_PUBLIC_CF_IMAGES_BASE_URL=https://imagedelivery.net
NEXT_PUBLIC_CF_ACCOUNT_ID=your_account_id_here

# Cloudflare R2 (for videos)
NEXT_PUBLIC_CF_R2_PUBLIC_URL=https://your-bucket.r2.dev
CF_R2_BUCKET_NAME=mlrit-media
